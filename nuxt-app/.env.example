# Ollama endpoint (remote server)
OLLAMA_API_URL=

# OpenAI-compatible endpoint (Groq/OpenAI/etc.)
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Neon Auth + JWT (optional, enables Neon-based auth flow)
# NEON_AUTH_URL=https://your-neon-auth-host/auth
# NEON_JWKS_URL=https://your-neon-auth-host/auth/.well-known/jwks.json
# NEON_AUTH_ANON_KEY=
# NEON_OAUTH_PROVIDERS=google,github
# Optional strict JWT validation
# NEON_JWT_ISSUER=
# NEON_JWT_AUDIENCE=

# Redis (optional accelerator — queue still persisted to PostgreSQL)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL (Prisma)
# Primary DB (recommended: Neon pooled URL)
DATABASE_URL=postgresql://postgres:yourpassword@your-neon-host:5432/ragdb?sslmode=require

# Optional explicit primary alias (higher priority than DATABASE_URL)
# DATABASE_PRIMARY_URL=postgresql://postgres:yourpassword@your-neon-host:5432/ragdb?sslmode=require

# Fallback DB (used when primary is unreachable)
# DATABASE_FALLBACK_URL=postgresql://postgres:yourpassword@localhost:5432/ragdb

# Optional fallback parts (used if DATABASE_FALLBACK_URL is not provided)
# DATABASE_FALLBACK_HOST=localhost
# DATABASE_FALLBACK_PORT=5432
# DATABASE_FALLBACK_NAME=ragdb
# DATABASE_FALLBACK_USER=postgres
# DATABASE_FALLBACK_PASSWORD=yourpassword

# Legacy single-DB parts (used only if no URL is provided)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=ragdb
# DATABASE_USER=postgres
# DATABASE_PASSWORD=yourpassword

# JWT secret — use a long random string (32+ chars)
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
