{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "npx prisma generate ; nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "npx prisma migrate reset --force",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "bcryptjs": "^3.0.3",
    "daisyui": "^5.5.19",
    "dompurify": "^3.4.2",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "marked": "^18.0.3",
    "nuxt": "^4.4.4",
    "openai": "^6.37.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "uuid": "^14.0.0",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
